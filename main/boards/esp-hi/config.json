{
    "target": "esp32c3",
    "builds": [
        {
            "name": "esp-hi",
            "sdkconfig_append": [
                "CONFIG_IDF_TARGET=\"esp32c3\"",
                "CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y",
                "CONFIG_PARTITION_TABLE_CUSTOM_FILENAME=\"partitions/v2/4m.csv\"",
                "CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=3",
                "CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=4",
                "CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=16",
                "CONFIG_ESP_WIFI_RX_MGMT_BUF_NUM_DEF=3",
                "CONFIG_ESP_WIFI_MGMT_SBUF_NUM=16",
                "CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=n",
                "CONFIG_ESP_WIFI_RX_BA_WIN=3",
                "CONFIG_ESP_WIFI_ENABLE_WPA3_SAE=n",
                "CONFIG_ESP_WIFI_ENABLE_WPA3_OWE_STA=n",
                "CONFIG_ESP_WIFI_ESPNOW_MAX_ENCRYPT_NUM=0",
                "CONFIG_ESP_WIFI_ENTERPRISE_SUPPORT=n",
                "CONFIG_ESP_CONSOLE_NONE=y",
                "CONFIG_ESP_MAIN_TASK_STACK_SIZE=7168",
                "CONFIG_ESP_HI_WEB_CONTROL_ENABLED=y",
                "CONFIG_ESP_HI_MDNS_HOSTNAME=\"esp-hi\"",
                "CONFIG_FREERTOS_HZ=1000",
                "CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=768",
                "CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024",
                "CONFIG_HTTPD_MAX_URI_LEN=256",
                "CONFIG_LOG_DEFAULT_LEVEL_WARN=y",
                "CONFIG_LOG_DYNAMIC_LEVEL_CONTROL=n",
                "CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=n",
                "CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=n",
                "CONFIG_FREERTOS_USE_TRACE_FACILITY=n",
                "CONFIG_LWIP_MAX_SOCKETS=6",
                "CONFIG_LWIP_MAX_ACTIVE_TCP=8",
                "CONFIG_LWIP_MAX_LISTENING_TCP=4",
                "CONFIG_LWIP_MAX_UDP_PCBS=8",
                "CONFIG_LWIP_MAX_RAW_PCBS=4",
                "CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=8",
                "CONFIG_LWIP_TCP_RECVMBOX_SIZE=6",
                "CONFIG_LWIP_TCP_ACCEPTMBOX_SIZE=2",
                "CONFIG_LWIP_TCP_SND_BUF_DEFAULT=2920",
                "CONFIG_LWIP_TCP_WND_DEFAULT=2920",
                "CONFIG_LWIP_TCP_QUEUE_OOSEQ=n",
                "CONFIG_LWIP_IPV6=n",
                "CONFIG_LWIP_TCPIP_TASK_STACK_SIZE=2048",
                "CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y",
                "CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=4096",
                "CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=2048",
                "CONFIG_NEWLIB_NANO_FORMAT=y",
                "CONFIG_LANGUAGE_ZH_CN=n",
                "CONFIG_LANGUAGE_KO_KR=y",
                "CONFIG_USE_ESP_WAKE_WORD=y",
                "CONFIG_SR_WN_WN9S_NIHAOXIAOZHI=n",
                "CONFIG_SR_WN_WN9S_HIESP=y",
                "CONFIG_SR_WN_WN9S_HIJASON=n",
                "CONFIG_COMPILER_OPTIMIZATION_SIZE=y",
                "CONFIG_CODEC_DATA_ADC_SUPPORT=y"
            ]
        }
    ]
}
