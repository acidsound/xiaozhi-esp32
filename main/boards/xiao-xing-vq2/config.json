{
    "target": "esp32s3",
    "builds": [
        {
            "name": "xiao-xing-vq2",
            "sdkconfig_append": [
                "CONFIG_IDF_TARGET=\"esp32s3\"",
                "CONFIG_BOARD_TYPE_XIAO_XING_VQ2=y",
                "CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y",
                "CONFIG_PARTITION_TABLE_CUSTOM_FILENAME=\"partitions/v2/16m.csv\"",
                "CONFIG_SPIRAM=y",
                "CONFIG_SPIRAM_MODE_OCT=y",
                "CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y",
                "CONFIG_ESP_HI_WEB_CONTROL_ENABLED=y",
                "CONFIG_ESP_HI_MDNS_HOSTNAME=\"xiao-xing-vq2\"",
                "CONFIG_LANGUAGE_ZH_CN=n",
                "CONFIG_LANGUAGE_KO_KR=y",
                "CONFIG_USE_AFE_WAKE_WORD=n",
                "CONFIG_USE_CUSTOM_WAKE_WORD=y",
                "CONFIG_CUSTOM_WAKE_WORD=\"lu pa ya\"",
                "CONFIG_CUSTOM_WAKE_WORD_DISPLAY=\"루파야\"",
                "CONFIG_CUSTOM_WAKE_WORD_THRESHOLD=10",
                "CONFIG_SR_WN_WN9_NIHAOXIAOZHI_TTS=n",
                "CONFIG_SR_MN_CN_NONE=n",
                "CONFIG_SR_MN_CN_MULTINET5_RECOGNITION_QUANT8=y",
                "CONFIG_COMPILER_OPTIMIZATION_SIZE=y"
            ]
        }
    ]
}
